    },
    {
      "text": "%pyspark\n# ── 1. Initialise SparkSession and load data from HDFS ────────────────────────\nfrom pyspark.sql import SparkSession\nfrom pyspark.sql.functions import col, count, avg, round, desc, month, hour\n\nspark \u003d SparkSession.builder \\\n    .appName(\"NYC Taxi EDA — Zeppelin\") \\\n    .config(\"spark.executor.memory\", \"2g\") \\\n    .getOrCreate()\n\nHDFS_PATH \u003d \"hdfs://namenode:9000/taxi/processed\"\ndf \u003d spark.read.parquet(HDFS_PATH)\n\nprint(f\"Rows loaded from HDFS : {df.count():,}\")\nprint(f\"Columns               : {len(df.columns)}\")\nprint(f\"Schema:\")\ndf.printSchema()",
      "user": "anonymous",
      "dateUpdated": "2026-05-14 19:01:22.225",
      "progress": 0,
      "config": {
        "tableHide": false,
        "editorSetting": {
