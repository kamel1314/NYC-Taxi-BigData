      "text": "%pyspark\n# ── 5. Top 10 Busiest Pickup Locations ───────────────────────────────────────\n# Switch to Bar Chart — keys: PULocationID, values: trip_count\n\ntop_locations \u003d df \\\n    .groupBy(\"PULocationID\") \\\n    .agg(\n        count(\"*\").alias(\"trip_count\"),\n        round(avg(\"fare_amount\"), 2).alias(\"avg_fare\")\n    ) \\\n    .orderBy(desc(\"trip_count\")) \\\n    .limit(10)\n\nz.show(top_locations)",
