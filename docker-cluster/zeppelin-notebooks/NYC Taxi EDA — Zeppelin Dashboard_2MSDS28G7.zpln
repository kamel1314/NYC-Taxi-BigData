    {
      "text": "%pyspark\n# ── 3. Monthly Trip Volume and Average Fare ───────────────────────────────────\n# Switch to Bar Chart view — keys: pickup_month, values: trip_count or avg_fare\nfrom pyspark.sql.functions import month as spark_month\n\nmonthly_stats \u003d df \\\n    .withColumn(\"pickup_month\", spark_month(col(\"tpep_pickup_datetime\"))) \\\n    .groupBy(\"pickup_month\") \\\n    .agg(\n        count(\"*\").alias(\"trip_count\"),\n        round(avg(\"fare_amount\"), 2).alias(\"avg_fare\"),\n        round(avg(\"trip_distance\"), 2).alias(\"avg_distance\")\n    ) \\\n    .orderBy(\"pickup_month\")\n\nz.show(monthly_stats)",
