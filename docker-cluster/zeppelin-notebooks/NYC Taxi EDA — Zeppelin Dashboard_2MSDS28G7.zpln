    {
      "text": "%pyspark\n# ── 4. Fare Distribution by Payment Type ─────────────────────────────────────\n# payment_type: 1\u003dCredit Card, 2\u003dCash, 3\u003dNo Charge, 4\u003dDispute, 5\u003dUnknown\n# Switch to Pie Chart view to see payment method breakdown\n\npayment_map \u003d {1: \"Credit Card\", 2: \"Cash\", 3: \"No Charge\", 4: \"Dispute\", 5: \"Unknown\", 6: \"Voided\"}\n\nfrom pyspark.sql.functions import when\n\npayment_stats \u003d df \\\n    .withColumn(\"payment_label\",\n        when(col(\"payment_type\") \u003d\u003d 1, \"Credit Card\")\n        .when(col(\"payment_type\") \u003d\u003d 2, \"Cash\")\n        .when(col(\"payment_type\") \u003d\u003d 3, \"No Charge\")\n        .when(col(\"payment_type\") \u003d\u003d 4, \"Dispute\")\n        .otherwise(\"Other\")\n    ) \\\n    .groupBy(\"payment_label\") \\\n    .agg(\n        count(\"*\").alias(\"trip_count\"),\n        round(avg(\"fare_amount\"), 2).alias(\"avg_fare\")\n    ) \\\n    .orderBy(desc(\"trip_count\"))\n\nz.show(payment_stats)",
      "user": "anonymous",
      "dateUpdated": "2026-05-14 19:01:53.001",
      "progress": 66,
      "config": {
