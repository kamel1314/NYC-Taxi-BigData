      "id": "paragraph_006",
      "dateCreated": "2026-05-14 01:47:57.612",
      "dateStarted": "2026-05-14 19:01:54.937",
      "dateFinished": "2026-05-14 19:01:56.418",
      "status": "FINISHED"
    },
    {
      "text": "%pyspark\n# ── 6. Weekend vs Weekday — Trip Count and Average Fare ───────────────────────\n# Switch to Bar Chart — keys: day_type, values: trip_count or avg_fare\nfrom pyspark.sql.functions import dayofweek\n\nweekend_stats \u003d df \\\n    .withColumn(\"pickup_day\", dayofweek(col(\"tpep_pickup_datetime\"))) \\\n    .withColumn(\"day_type\",\n        when(col(\"pickup_day\").isin([1, 7]), \"Weekend\")\n        .otherwise(\"Weekday\")\n    ) \\\n    .groupBy(\"day_type\") \\\n    .agg(\n        count(\"*\").alias(\"trip_count\"),\n        round(avg(\"fare_amount\"), 2).alias(\"avg_fare\"),\n        round(avg(\"trip_distance\"), 2).alias(\"avg_distance\")\n    ) \\\n    .orderBy(\"day_type\")\n\nz.show(weekend_stats)\nprint(\"\\nKey insight: Weekend trips tend to have higher fares due to longer night-time rides.\")",
      "user": "anonymous",
      "dateUpdated": "2026-05-14 19:01:56.437",
