    {
      "text": "%pyspark\n# ── 2. Trips and Average Fare by Pickup Hour ─────────────────────────────────\n# Switch to Bar Chart view in Zeppelin to visualise this table\nfrom pyspark.sql.functions import hour as spark_hour\n\ntrips_by_hour \u003d df \\\n    .withColumn(\"pickup_hour\", spark_hour(col(\"tpep_pickup_datetime\"))) \\\n    .groupBy(\"pickup_hour\") \\\n    .agg(\n        count(\"*\").alias(\"trip_count\"),\n        round(avg(\"fare_amount\"), 2).alias(\"avg_fare\")\n    ) \\\n    .orderBy(\"pickup_hour\")\n\nz.show(trips_by_hour)",
      "user": "anonymous",
      "dateUpdated": "2026-05-14 19:01:46.032",
